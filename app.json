{
  "expo": {
    "name": "Airbnb",
    "slug": "airbnb",
    "version": "0.1.0",
    "sdkVersion": "51.0.21",
    "orientation": "portrait",
    "icon": "./assets/app-specifics/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "airbnb",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/app-specifics/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.github.icastillejogomez.reactNativeAirbnb.ios"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-specifics/icon.png",
        "backgroundColor": "#FF5A5F"
      },
      "package": "com.github.icastillejogomez.reactNativeAirbnb.android"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "font": [
            "assets/fonts/SpaceMono-Regular.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}